{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Professional profile data for a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "headline": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "industry": { "type": "string" },
        "experience": { "type": "array" },
        "education": { "type": "array" },
        "skills": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Post": {
      "title": "Feed Post",
      "description": "A post in the professional feed.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorHeadline": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "imageURL": { "type": "string" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["authorId", "content", "createdAt"]
    },
    "Like": {
      "title": "Post Like",
      "description": "A like on a post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId", "createdAt"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "content", "createdAt"]
    },
    "Job": {
      "title": "Job Listing",
      "description": "A professional job opportunity.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "location": { "type": "string" },
        "description": { "type": "string" },
        "postedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "company", "createdAt"]
    },
    "Connection": {
      "title": "User Connection",
      "description": "Professional relationship between two users.",
      "type": "object",
      "properties": {
        "user1": { "type": "string" },
        "user2": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["user1", "user2", "status", "createdAt"]
    },
    "Message": {
      "title": "Direct Message",
      "description": "A message within a chat.",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "content", "createdAt"]
    },
    "Chat": {
      "title": "Chat Conversation",
      "description": "A conversation between two users.",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["participants", "updatedAt"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "System or user-triggered notification.",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment", "connection_request", "connection_accepted", "message"] },
        "postId": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["recipientId", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "posts/{postId}": {
      "schema": "Post",
      "description": "Main feed posts"
    },
    "posts/{postId}/likes/{likeId}": {
      "schema": "Like",
      "description": "Likes on a specific post"
    },
    "posts/{postId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on a specific post"
    },
    "jobs/{jobId}": {
      "schema": "Job",
      "description": "Job listings"
    },
    "connections/{connectionId}": {
      "schema": "Connection",
      "description": "User connections"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversations"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages in a conversation"
    },
    "users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
